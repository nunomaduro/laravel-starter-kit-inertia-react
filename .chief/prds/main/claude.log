{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013WPBQUtupjdoAoiWJ2mA8z","type":"tool_result","content":"     1→#!/bin/sh\n     2→#\n     3→# Pre-commit hook: Pint (PHP style), model/seeder and docs checks.\n     4→# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit\n     5→#\n     6→\n     7→set -e\n     8→ROOT=\"$(git rev-parse --show-toplevel)\"\n     9→cd \"$ROOT\"\n    10→\n    11→# 1. Laravel Pint (PHP code style)\n    12→echo \"📝 Running Pint...\"\n    13→if ! vendor/bin/pint --test --dirty 2>/dev/null; then\n    14→    echo \"❌ Pint check failed. Run: vendor/bin/pint --dirty --format agent\"\n    15→    exit 1\n    16→fi\n    17→echo \"✅ Pint passed\"\n    18→\n    19→# 3. New models: seeders and specs (exclude Concerns/ traits, Scopes/, and known non-models)\n    20→STAGED_MODELS=$(git diff --cached --name-only --diff-filter=A | grep -E '^app/Models/.*\\.php$' | grep -v -E '^app/Models/(Concerns|Scopes)/' || true)\n    21→SKIP_NAMES=\"BelongsToOrganization OrganizationScope Categorizable TermsVersion UserTermsAcceptance\"\n    22→\n    23→if [ -n \"$STAGED_MODELS\" ]; then\n    24→    MISSING_SEEDERS=\"\"\n    25→    MISSING_SPECS=\"\"\n    26→    for MODEL_FILE in $STAGED_MODELS; do\n    27→        MODEL_NAME=$(basename \"$MODEL_FILE\" .php)\n    28→        case \" $SKIP_NAMES \" in *\" $MODEL_NAME \"*) continue ;; esac\n    29→        SEEDER_FOUND=false\n    30→        for CATEGORY in essential development production; do\n    31→            if [ -f \"database/seeders/$CATEGORY/${MODEL_NAME}Seeder.php\" ]; then\n    32→                SEEDER_FOUND=true\n    33→                break\n    34→            fi\n    35→        done\n    36→        if [ \"$SEEDER_FOUND\" = false ]; then\n    37→            MISSING_SEEDERS=\"${MISSING_SEEDERS}${MISSING_SEEDERS:+, }$MODEL_NAME\"\n    38→        fi\n    39→        if [ ! -f \"database/seeders/specs/${MODEL_NAME}.json\" ]; then\n    40→            MISSING_SPECS=\"${MISSING_SPECS}${MISSING_SPECS:+, }$MODEL_NAME\"\n    41→        fi\n    42→    done\n    43→\n    44→    if [ -n \"$MISSING_SEEDERS\" ] || [ -n \"$MISSING_SPECS\" ]; then\n    45→        echo \"❌ Pre-commit validation failed!\"\n    46→        [ -n \"$MISSING_SEEDERS\" ] && echo \"Missing seeders: $MISSING_SEEDERS\"\n    47→        [ -n \"$MISSING_SPECS\" ] && echo \"Missing specs: $MISSING_SPECS\"\n    48→        echo \"Fix: php artisan make:model:full <Model> --category=development\"\n    49→        echo \"Or skip: git commit --no-verify\"\n    50→        exit 1\n    51→    fi\n    52→fi\n    53→\n    54→# 4. Documentation\n    55→echo \"📚 Checking documentation...\"\n    56→if ! php artisan docs:sync --check >/dev/null 2>&1; then\n    57→    echo \"⚠️  Documentation incomplete. Run: php artisan docs:sync --check\"\n    58→    echo \"Skip with: git commit --no-verify\"\n    59→    exit 1\n    60→fi\n    61→echo \"✅ Docs OK\"\n    62→\n    63→exit 0\n    64→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"d67112a8-e0f1-41f5-bf61-d36ba5bdd92e","uuid":"59b85724-5461-41f6-b163-803c8d15799e","tool_use_result":{"type":"text","file":{"filePath":"/Users/apple/Code/cogneiss/Products/laravel-starter-kit-inertia-react/.git/hooks/pre-commit","content":"#!/bin/sh\n#\n# Pre-commit hook: Pint (PHP style), model/seeder and docs checks.\n# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit\n#\n\nset -e\nROOT=\"$(git rev-parse --show-toplevel)\"\ncd \"$ROOT\"\n\n# 1. Laravel Pint (PHP code style)\necho \"📝 Running Pint...\"\nif ! vendor/bin/pint --test --dirty 2>/dev/null; then\n    echo \"❌ Pint check failed. Run: vendor/bin/pint --dirty --format agent\"\n    exit 1\nfi\necho \"✅ Pint passed\"\n\n# 3. New models: seeders and specs (exclude Concerns/ traits, Scopes/, and known non-models)\nSTAGED_MODELS=$(git diff --cached --name-only --diff-filter=A | grep -E '^app/Models/.*\\.php$' | grep -v -E '^app/Models/(Concerns|Scopes)/' || true)\nSKIP_NAMES=\"BelongsToOrganization OrganizationScope Categorizable TermsVersion UserTermsAcceptance\"\n\nif [ -n \"$STAGED_MODELS\" ]; then\n    MISSING_SEEDERS=\"\"\n    MISSING_SPECS=\"\"\n    for MODEL_FILE in $STAGED_MODELS; do\n        MODEL_NAME=$(basename \"$MODEL_FILE\" .php)\n        case \" $SKIP_NAMES \" in *\" $MODEL_NAME \"*) continue ;; esac\n        SEEDER_FOUND=false\n        for CATEGORY in essential development production; do\n            if [ -f \"database/seeders/$CATEGORY/${MODEL_NAME}Seeder.php\" ]; then\n                SEEDER_FOUND=true\n                break\n            fi\n        done\n        if [ \"$SEEDER_FOUND\" = false ]; then\n            MISSING_SEEDERS=\"${MISSING_SEEDERS}${MISSING_SEEDERS:+, }$MODEL_NAME\"\n        fi\n        if [ ! -f \"database/seeders/specs/${MODEL_NAME}.json\" ]; then\n            MISSING_SPECS=\"${MISSING_SPECS}${MISSING_SPECS:+, }$MODEL_NAME\"\n        fi\n    done\n\n    if [ -n \"$MISSING_SEEDERS\" ] || [ -n \"$MISSING_SPECS\" ]; then\n        echo \"❌ Pre-commit validation failed!\"\n        [ -n \"$MISSING_SEEDERS\" ] && echo \"Missing seeders: $MISSING_SEEDERS\"\n        [ -n \"$MISSING_SPECS\" ] && echo \"Missing specs: $MISSING_SPECS\"\n        echo \"Fix: php artisan make:model:full <Model> --category=development\"\n        echo \"Or skip: git commit --no-verify\"\n        exit 1\n    fi\nfi\n\n# 4. Documentation\necho \"📚 Checking documentation...\"\nif ! php artisan docs:sync --check >/dev/null 2>&1; then\n    echo \"⚠️  Documentation incomplete. Run: php artisan docs:sync --check\"\n    echo \"Skip with: git commit --no-verify\"\n    exit 1\nfi\necho \"✅ Docs OK\"\n\nexit 0\n","numLines":64,"startLine":1,"totalLines":64}}}
