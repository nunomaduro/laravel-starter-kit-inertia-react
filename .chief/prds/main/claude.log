=> $configKey) {\n   371→                    config()->set($configKey, $settings->{$property});\n   372→                }\n   373→            } catch (Throwable) {\n   374→                // Settings table may not exist yet (fresh install, migrations pending).\n   375→                // Skip this group silently — config defaults from env remain in effect.\n   376→                continue;\n   377→            }\n   378→        }\n   379→\n   380→        // Cross-map PrismSettings API keys to Laravel AI SDK config\n   381→        try {\n   382→            $prism = resolve(PrismSettings::class);\n   383→\n   384→            foreach (self::AI_KEY_CROSS_MAP as $property => $configKey) {\n   385→                config()->set($configKey, $prism->{$property});\n   386→            }\n   387→        } catch (Throwable) {\n   388→            // PrismSettings not available yet — skip silently.\n   389→        }\n   390→    }\n   391→\n   392→    /**\n   393→     * Get all config keys that are overridable per-organization.\n   394→     *\n   395→     * @return array<string, string> Map of \"group.property\" => \"config.key\"\n   396→     */\n   397→    public static function orgOverridableKeys(): array\n   398→    {\n   399→        $keys = [];\n   400→\n   401→        foreach (self::OVERLAY_MAP as $settingsClass => $config) {\n   402→            if (! $config['orgOverridable']) {\n   403→                continue;\n   404→            }\n   405→\n   406→            $group = $settingsClass::group();\n   407→\n   408→            foreach ($config['map'] as $property => $configKey) {\n   409→                $keys[sprintf('%s.%s', $group, $property)] = $configKey;\n   410→            }\n   411→        }\n   412→\n   413→        return $keys;\n   414→    }\n   415→\n   416→    public function boot(): void\n   417→    {\n   418→        self::applyOverlay();\n   419→    }\n   420→}\n   421→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered 