ersion.id}\n    87→                                className=\"rounded-lg border border-border p-4\"\n    88→                            >\n    89→                                <div className=\"flex items-start gap-3\">\n    90→                                    <Checkbox\n    91→                                        id={`accept-${version.id}`}\n    92→                                        checked={acceptedIds.includes(\n    93→                                            version.id,\n    94→                                        )}\n    95→                                        onCheckedChange={() =>\n    96→                                            toggleVersion(version.id)\n    97→                                        }\n    98→                                    />\n    99→                                    <div className=\"min-w-0 flex-1\">\n   100→                                        <label\n   101→                                            htmlFor={`accept-${version.id}`}\n   102→                                            className=\"cursor-pointer font-semibold\"\n   103→                                        >\n   104→                                            {version.title}\n   105→                                            <span className=\"ml-2 text-xs font-normal text-muted-foreground\">\n   106→                                                ({version.type_label} ·{' '}\n   107→                                                {version.effective_at})\n   108→                                            </span>\n   109→                                        </label>\n   110→                                        {version.summary && (\n   111→                                            <p className=\"mt-1 text-sm text-muted-foreground\">\n   112→                                                {version.summary}\n   113→                                            </p>\n   114→                                        )}\n   115→         