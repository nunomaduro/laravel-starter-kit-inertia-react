                      )}\n                            </span>\n                            {item.email !== undefined && item.email !== null && (\n                                <span className=\"text-muted-foreground\">\n                                    {String(item.email)}\n                                </span>\n                            )}\n                            {item.status != null && (\n                                <span className=\"rounded bg-muted px-1.5 py-0.5 text-xs\">\n                                    {String(item.status)}\n                                </span>\n                            )}\n                        </li>\n                    ))}\n                </ul>\n            )}\n        </section>\n    );\n}\n","structuredPatch":[{"oldStart":1,"oldLines":5,"newStart":1,"newLines":7,"lines":[" import React from 'react';"," ","+import type { JSX } from 'react';","+"," export interface DataListBlockProps {","     dataSource: string;","     title?: string;"]}],"userModified":false,"replaceAll":false}}
