      {description && (\n                    <meta property=\"og:description\" content={description} />\n                )}\n                <meta property=\"og:title\" content={page.name} />\n                {image && <meta property=\"og:image\" content={image} />}\n            </Head>\n            <div className=\"container py-8\">\n                <Render config={puckConfig} data={data} />\n            </div>\n        </PageViewLayout>\n    );\n}\n","structuredPatch":[{"oldStart":40,"oldLines":7,"newStart":40,"newLines":8,"lines":["                 {image && <meta property=\"og:image\" content={image} />}","             </Head>","             <div className=\"container py-8\">","-                <Render config={puckConfig} data={data} />","+                {/* eslint-disable-next-line @typescript-eslint/no-explicit-any */}","+                <Render config={puckConfig} data={data as any} />","             </div>","         </PageViewLayout>","     );"]}],"userModified":false,"replaceAll":false}}
