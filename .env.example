APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# API version shown in OpenAPI docs (Scramble)
API_VERSION=0.0.1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Optional: comma-separated IPs or CIDR ranges for routes using ip.whitelist middleware (e.g. admin)
# IP_WHITELIST=

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Error tracking (sentry/sentry-laravel). Leave empty to disable.
# SENTRY_LARAVEL_DSN=
# SENTRY_SAMPLE_RATE=1.0
# SENTRY_TRACES_SAMPLE_RATE=null

# Google Analytics 4 (spatie/laravel-analytics). Server-side; set credentials path and property ID.
# GOOGLE_ANALYTICS_CREDENTIALS_PATH=
# ANALYTICS_PROPERTY_ID=

# Slack notifications (e.g. critical errors, failed jobs). Webhook URL from Slack app.
# SLACK_WEBHOOK_URL=

# Backups (spatie/laravel-backup). Destination disk; default config uses local.
# BACKUP_DISK=local
# BACKUP_ARCHIVE_PASSWORD=

# Full-text search (Laravel Scout + Typesense). Laravel Herd uses port 8108 and key LARAVEL-HERD.
# SCOUT_DRIVER=typesense
# TYPESENSE_API_KEY=LARAVEL-HERD
# TYPESENSE_HOST=localhost
# TYPESENSE_PORT=8108

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# For Reverb WebSockets: set BROADCAST_CONNECTION=reverb, run `php artisan reverb`, and configure REVERB_* / VITE_REVERB_* below
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST=localhost
# REVERB_PORT=8080
# REVERB_SCHEME=http
# VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# VITE_REVERB_HOST="${REVERB_HOST}"
# VITE_REVERB_PORT="${REVERB_PORT}"
# VITE_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# When using Laravel Horizon, set QUEUE_CONNECTION=redis and run: php artisan horizon
# HORIZON_PATH=horizon

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 (required when using the s3 filesystem disk)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
# Optional: custom endpoint (e.g. MinIO) and public URL
# AWS_ENDPOINT=
# AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Security headers (spatie/laravel-csp)
CSP_ENABLED=true
CSP_ENABLED_WHILE_HOT_RELOADING=true
CSP_NONCE_ENABLED=false
# CSP_REPORT_URI=

# Response cache (spatie/laravel-responsecache) – guest GET only; excludes admin/auth
RESPONSE_CACHE_ENABLED=false
RESPONSE_CACHE_LIFETIME=604800

# Feature flags (laravel/pennant); stephenjude/filament-feature-flags for admin UI
PENNANT_STORE=database
# Comma-separated feature keys to globally disable for everyone (e.g. blog,changelog,gamification)
# GLOBALLY_DISABLED_MODULES=

# Database-backed settings (spatie/laravel-settings); optional cache
# SETTINGS_CACHE_ENABLED=false

# Honeypot spam protection (spatie/laravel-honeypot)
HONEYPOT_ENABLED=true
HONEYPOT_NAME=my_name
HONEYPOT_RANDOMIZE=false
HONEYPOT_VALID_FROM_TIMESTAMP=true
HONEYPOT_VALID_FROM=valid_from
HONEYPOT_SECONDS=1

OPENROUTER_API_KEY=
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_HTTP_REFERER="${APP_URL}"
OPENROUTER_SITE_X_TITLE="${APP_NAME}"

PRISM_DEFAULT_PROVIDER=openrouter
# Best free thinking model: DeepSeek R1 0528 (performance on par with OpenAI o1)
# Alternatives: deepseek/deepseek-r1:free, tng/deepseek-r1t2-chimera:free
PRISM_DEFAULT_MODEL=deepseek/deepseek-r1-0528:free

# Provider-specific model defaults (optional - falls back to PRISM_DEFAULT_MODEL)
PRISM_OPENAI_DEFAULT_MODEL=gpt-4o-mini
PRISM_ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022
# PRISM_OLLAMA_DEFAULT_MODEL=llama3.2
# PRISM_MISTRAL_DEFAULT_MODEL=mistral-small-latest

RELAY_PUPPETEER_SERVER_TIMEOUT=60
RELAY_TOOLS_CACHE_DURATION=60

# Laravel AI SDK (optional - for agents, embeddings, images, etc.). Prism uses OpenRouter above.
# See docs/developer/backend/ai-sdk.md and prism.md for when to use which.
# Default provider for chat/agents: openai, openrouter, anthropic, etc. Use openrouter if you only set OPENROUTER_API_KEY.
# AI_DEFAULT=openrouter
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# COHERE_API_KEY=
# JINA_API_KEY=
# XAI_API_KEY=
# GROQ_API_KEY=
# ELEVENLABS_API_KEY=

# Laravel AI Memory (eznix86/laravel-ai-memory). Requires PostgreSQL + pgvector and config/ai.php embeddings/reranking.
# See docs/developer/backend/ai-memory.md.
# MEMORY_DIMENSIONS=1536
# MEMORY_SIMILARITY_THRESHOLD=0.5
# MEMORY_RECALL_LIMIT=10
# MEMORY_MIDDLEWARE_RECALL_LIMIT=5
# MEMORY_RECALL_OVERSAMPLE_FACTOR=2
# MEMORY_TABLE=memories

# Multi-tenancy. Set false for single-tenant (internal apps); hides org switcher and org management UI.
# See docs/developer/backend/single-tenant-mode.md
# MULTI_ORGANIZATION_ENABLED=true

# Billing (Stripe / Paddle / Lemon Squeezy)
DEFAULT_PAYMENT_GATEWAY=stripe
BILLING_CURRENCY=usd
BILLING_TRIAL_DAYS=14
BILLING_CREDIT_EXPIRATION_DAYS=365
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
PADDLE_VENDOR_ID=
PADDLE_VENDOR_AUTH_CODE=
PADDLE_PUBLIC_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_SANDBOX=true

# Lemon Squeezy (one-time products). Get credentials from https://app.lemonsqueezy.com/settings/api
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE=
LEMON_SQUEEZY_SIGNING_SECRET=
LEMON_SQUEEZY_GENERIC_VARIANT_ID=

# Filament Blueprint (optional). Set both to install via scripts/setup-filament-blueprint.sh
FILAMENT_BLUEPRINT_EMAIL=
FILAMENT_BLUEPRINT_LICENSE_KEY=
