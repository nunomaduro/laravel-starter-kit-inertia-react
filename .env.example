APP_ENV=local
# ─────────────────────────────────────────────────────────────────────────────
# Getting started
# ─────────────────────────────────────────────────────────────────────────────
#
#   CLI (recommended):   cp .env.example .env && php artisan app:install
#     Interactive TUI — covers every setup phase:
#       database · admin user · app name · tenancy mode · cache/session/queue
#       mail · search (Typesense) · AI providers · social auth (Google/GitHub)
#       S3 storage · broadcasting (Reverb) · SEO · monitoring (Sentry) · demo data
#     Supports --resume to continue after a failed run.
#     Supports --modules=users,content,billing to pre-select demo data modules.
#     CI/CD flags (fully unattended install):
#       --non-interactive
#       --admin-email=superadmin@example.com --admin-password=secret --admin-name="Admin"
#       --site-name="My App" --url=https://example.com
#       --mail-mailer=smtp --mail-from=hello@example.com
#       --tenancy=multi|single  [--org-name="My Org" for single mode]
#       --cache-driver=redis --redis-host=127.0.0.1 --redis-port=6379
#       --search-driver=typesense --typesense-key=xyz --typesense-host=localhost
#       --ai-provider=openrouter --ai-api-key=sk-...
#       --google-client-id=... --google-client-secret=...
#       --s3-bucket=my-bucket --s3-key=... --s3-secret=... --s3-region=us-east-1
#       --sentry-dsn=https://... --meta-title="My App" --meta-description="..."
#       --demo | --no-demo | --modules=users,content
#
#   GUI (browser):       cp .env.example .env && visit /install
#     15-step web installer — functionally identical to the TUI:
#       database · tables · admin · app · tenancy · infrastructure · mail · search
#       AI providers · social auth · S3 storage · broadcasting · SEO · monitoring · demo data
#     EnsureNotInstalled middleware blocks re-entry once setup_completed = true.
#
#   Upgrade existing:    php artisan app:upgrade
#     Runs pending migrations, re-seeds essential data, rebuilds caches.
#     Safe to run after any git pull or composer update.
#
#   Health check:        php artisan app:health
#     Verifies DB, migrations, cache, queue, mail, search, AI, Horizon, etc.
#     Use --json for CI / monitoring integrations.
#     Use --fail-on-warn to treat warnings as failures (strict mode).
#
#   Admin settings:      /system/settings  (29 settings groups, all DB-backed)
#     Everything below this line can also be set via Filament → Settings.
#     The only true .env requirements are the infrastructure values marked [env-only].
#
# .env can stay nearly empty before running the installer.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# [env-only] Core application identity
# ─────────────────────────────────────────────────────────────────────────────
# APP_ENV       — local | staging | production  (controls debug defaults, cache, etc.)
# APP_KEY       — generated automatically by app:install  (php artisan key:generate)
# APP_URL       — used before AppSettings are loaded (webhooks, queue, CLI); also
#                 set via DB after install: Filament → Settings → App
# APP_DEBUG     — true in local; MUST be false in production
# DEBUGBAR_ENABLED — show Laravel Debugbar (default true when APP_DEBUG; set false to hide)
#
# APP_ENV=local
# APP_KEY=
# APP_URL=http://localhost
# APP_DEBUG=false
# DEBUGBAR_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# [env-only] Database — only needed if NOT using SQLite.
# app:install will prompt for these and write them to .env automatically.
# ─────────────────────────────────────────────────────────────────────────────
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# [env-only] Cache / Session / Queue
# Defaults to "database" driver — works out of the box with zero extra config.
# app:install offers a Redis upgrade step.
# ─────────────────────────────────────────────────────────────────────────────
# CACHE_STORE=database
# SESSION_DRIVER=database
# QUEUE_CONNECTION=database

# ─────────────────────────────────────────────────────────────────────────────
# [env-only] Redis — required only when using redis for cache/session/queue.
# ─────────────────────────────────────────────────────────────────────────────
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# [env-only] Typesense — server credentials stay in .env (infrastructure).
# The search driver selection is set via Filament Settings > Search or app:install.
# ─────────────────────────────────────────────────────────────────────────────
# TYPESENSE_API_KEY=
# TYPESENSE_HOST=localhost
# TYPESENSE_PORT=8108

# ─────────────────────────────────────────────────────────────────────────────
# [env-only] Frontend (Vite) — values baked into the JS bundle at build time.
# ─────────────────────────────────────────────────────────────────────────────
# VITE_GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Thesys C1 (generative UI) — used by DataTable Visualize and any other Thesys features
# Get an API key at https://www.thesys.dev — store only in .env, never commit.
# ─────────────────────────────────────────────────────────────────────────────
# THESYS_API_KEY=
# THESYS_MODEL=c1-nightly

# DataTable AI model override (optional; defaults to app AI/Prism config)
# DATA_TABLE_AI_MODEL=

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Model HashId, Laravel Mails, Governor
# Set in production for secure HashIds; others have defaults in config.
# ─────────────────────────────────────────────────────────────────────────────
# HASHID_SALT=your-secret-salt-string
# MAILS_LOGGING_ENABLED=true
# MAILS_ENCRYPTED=true
# GOVERNOR_SUPERADMINS=
# GOVERNOR_ADMINS=

# ─────────────────────────────────────────────────────────────────────────────
# Everything below is DB-backed — set via app:install or Filament → Settings.
# These lines exist only as documentation; the installer manages them.
# "Future" settings follow the same pattern: Settings class + migration + Filament
# page + OVERLAY_MAP entry. No new .env vars should be needed.
# ─────────────────────────────────────────────────────────────────────────────

# App name / URL / timezone / locale   → Settings > App
# Theme & branding                     → Settings > Theme / Branding
# Tenancy mode                         → Settings > Tenancy
# Mail (mailer, SMTP, from address)    → Settings > Mail
# Stripe / Paddle / LemonSqueezy       → Settings > Billing / Payments
# Slack / Postmark / Resend            → Settings > Integrations
# AI providers (OpenAI, Anthropic…)    → Settings > AI / Prism
# Full-text search (Typesense driver)  → Settings > Search
# Social auth (Google / GitHub OAuth)  → Settings > Auth
# File storage (local / S3)            → Settings > Filesystem
# Broadcasting (Reverb WebSockets)     → Settings > Broadcasting
# SEO meta tags                        → Settings > SEO
# Error tracking (Sentry DSN)          → Settings > Monitoring
# Logging (channel, level, Slack hook) → Settings > Logging
# Password policy & 2FA enforcement    → Settings > Auth
# Cookie consent                       → Settings > Cookie Consent
# Backups (S3 destination)             → Settings > Backups
# CSP / security headers               → Settings > Security
# Feature flags                        → Settings > Features
# Performance / cache                  → Settings > Performance
# Activity log                         → Settings > Activity Log
# Impersonation                        → Settings > Impersonation
# Permissions (team mode)              → Settings > Permissions
# Media / uploads                      → Settings > Media
# Memory / AI embeddings               → Settings > Memory
# Billing config                       → Settings > Billing
