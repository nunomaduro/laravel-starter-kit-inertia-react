{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "nunomaduro/laravel-starter-kit-inertia-react",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "repositories": [
        {
            "name": "filament",
            "type": "composer",
            "url": "https://packages.filamentphp.com/composer"
        },
        {
            "type": "vcs",
            "url": "https://github.com/coding-sunshine/laravel-data-table"
        },
        {
            "type": "vcs",
            "url": "https://github.com/coding-sunshine/laravel-ai-memory"
        }
    ],
    "require": {
        "php": "^8.5.0",
        "a909m/filament-statefusion": "^2.3.0",
        "akaunting/laravel-money": "^6.0.2",
        "alizharb/filament-activity-log": "^1.3.1",
        "askedio/laravel-soft-cascade": "^12.0",
        "backstage/laravel-mails": "^2.1",
        "beyondcode/laravel-vouchers": "^2.3",
        "cjmellor/level-up": "^1.5.1",
        "dedoc/scramble": "^0.13.14",
        "deligoez/laravel-model-hashid": "^4.0.1",
        "devrabiul/laravel-geo-genius": "^1.5",
        "essa/api-tool-kit": "^3.1.0",
        "eznix86/laravel-ai-memory": "dev-main",
        "filament/filament": "^5.3.3",
        "filament/spatie-laravel-settings-plugin": "^5.3.3",
        "genealabs/laravel-governor": ">=0.22",
        "inertiajs/inertia-laravel": "^2.0.22",
        "jijunair/laravel-referral": "^1.0.4",
        "kalnoy/nestedset": "^6.0.6",
        "laravel-workflow/laravel-workflow": "^1.0.70",
        "laravel-workflow/waterline": "^1.0.15",
        "laravel/ai": "^0.2.8",
        "laravel/fortify": "^1.36.1",
        "laravel/framework": "^12.54.1",
        "laravel/horizon": "^5.45.3",
        "laravel/mcp": "^0.6.2",
        "laravel/pennant": "^1.21",
        "laravel/reverb": "^1.8.0",
        "laravel/sanctum": "^4.3.1",
        "laravel/scout": "^10.25.0",
        "laravel/slack-notification-channel": "^3.7",
        "laravel/socialite": "^5.25.0",
        "laravel/tinker": "^2.11.1",
        "laravel/wayfinder": "^0.1.14",
        "laravelcm/laravel-subscriptions": "^1.7.2",
        "laraveldaily/laravel-invoices": "^4.1.1",
        "league/flysystem-aws-s3-v3": "^3.32",
        "lemonsqueezy/laravel": "^1",
        "maatwebsite/excel": "^3.1.67",
        "machour/laravel-data-table": "dev-main",
        "martinpetricko/laravel-database-mail": "^2.0.3",
        "nunomaduro/essentials": "^1.2.0",
        "panphp/pan": "^0.1.8",
        "pgvector/pgvector": "^0.2.2",
        "prism-php/prism": "^0.99.21",
        "prism-php/relay": "^1.7",
        "pxlrbt/filament-excel": "^3.6.1",
        "saloonphp/saloon": "^3.15.0",
        "sentry/sentry-laravel": "^4.21.1",
        "socialiteproviders/github": "^4.1",
        "socialiteproviders/google": "^4.1",
        "spatie/browsershot": "^5.2.3",
        "spatie/eloquent-sortable": "5.0.1 as 4.99.0",
        "spatie/laravel-activitylog": "^4.12.1",
        "spatie/laravel-analytics": "^5.7.0",
        "spatie/laravel-backup": "^10.0.2",
        "spatie/laravel-cookie-consent": "^3.4.0",
        "spatie/laravel-cronless-schedule": "^1.3",
        "spatie/laravel-csp": "^3.23",
        "spatie/laravel-data": "^4.20.0",
        "spatie/laravel-honeypot": "^4.7.1",
        "spatie/laravel-medialibrary": "^11.21.0",
        "spatie/laravel-model-flags": "^1.4.2",
        "spatie/laravel-model-states": "^2.13.1",
        "spatie/laravel-pdf": "^2.4.0",
        "spatie/laravel-permission": "^7.2.3",
        "spatie/laravel-personal-data-export": "^4.3.2",
        "spatie/laravel-query-builder": "^6.4.4",
        "spatie/laravel-responsecache": "^8.3",
        "spatie/laravel-schemaless-attributes": "^2.6.0",
        "spatie/laravel-settings": "^3.7",
        "spatie/laravel-sitemap": "^8.1.0",
        "spatie/laravel-sluggable": "^3.8.0",
        "spatie/laravel-tags": "^4.11.0",
        "stechstudio/filament-impersonate": "^5.1",
        "stephenjude/filament-feature-flags": "^5.0.2",
        "stripe/stripe-php": "^19.4.1",
        "typesense/typesense-php": "^6.0",
        "wildside/userstamps": "^3.1.1"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.1.12",
        "fakerphp/faker": "^1.24.1",
        "filament/blueprint": "^2.1.2",
        "fruitcake/laravel-debugbar": "^4.1.3",
        "larastan/larastan": "^3.9.3",
        "laravel/boost": "^2.3.1",
        "laravel/pail": "^1.2.6",
        "laravel/pint": "^1.28.0",
        "laravel/telescope": "^5.18",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.1",
        "pestphp/pest": "^4.4.2",
        "pestphp/pest-plugin-browser": "^4.3.0",
        "pestphp/pest-plugin-laravel": "^4.1.0",
        "pestphp/pest-plugin-type-coverage": "^4.0.3",
        "rector/rector": "^2.3.8",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "bootstrap/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "bun install",
            "bun run build"
        ],
        "setup-blueprint": "bash scripts/setup-filament-blueprint.sh",
        "optimize-production": [
            "@php artisan config:cache",
            "@php artisan route:cache",
            "@php artisan filament:cache-components"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "bunx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"bun run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan docs:sync || true",
            "@php artisan filament:upgrade"
        ],
        "post-install-cmd": [
            "@php scripts/ensure-rector-bootstrap-stub.php"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan clear",
            "@update:requirements",
            "@php artisan boost:update --ansi || true",
            "@php artisan docs:sync || true",
            "@php scripts/ensure-rector-bootstrap-stub.php",
            "bash scripts/sync-data-table-from-vendor.sh || true"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "update:requirements": [
            "composer bump",
            "bunx npm-check-updates -u"
        ],
        "lint": [
            "rector",
            "pint --parallel",
            "bun run lint"
        ],
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run",
            "bun run test:lint"
        ],
        "test:unit": "XDEBUG_MODE=\"coverage\" pest --parallel --coverage --exactly=100.0",
        "test:quick": "pest --parallel --compact",
        "test:types": [
            "phpstan",
            "bun run test:types"
        ],
        "test": "@test:quick",
        "test:full": [
            "@test:type-coverage",
            "@test:unit",
            "@test:lint",
            "@test:types"
        ],
        "docs:check": "php artisan docs:sync --check",
        "docs:sync": "php artisan docs:sync",
        "docs:generate": "php artisan docs:sync --generate"
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "eznix86/laravel-ai-memory",
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
